# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push (VAPID) — npx web-push generate-vapid-keys 로 생성
# Vercel: Settings → Environment Variables → Production/Preview 모두 설정 후 Redeploy
VITE_VAPID_PUBLIC_KEY=

# Edge Function 시크릿 (Supabase Dashboard → Edge Functions → Secrets)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@gts.kr
